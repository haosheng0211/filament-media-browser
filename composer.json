{
    "name": "haosheng0211/filament-media-browser",
    "description": "A standalone Filament v3 media browser powered by Laravel Storage — no database required.",
    "keywords": [
        "filament",
        "media-browser",
        "file-browser",
        "laravel"
    ],
    "homepage": "https://github.com/haosheng0211/filament-media-browser",
    "license": "MIT",
    "authors": [
        {
            "name": "MrJin",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.0",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^10.0||^11.0||^12.0",
        "livewire/livewire": "^3.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0||^9.0",
        "pestphp/pest": "^2.0||^3.0||^4.0",
        "pestphp/pest-plugin-arch": "^2.0||^3.0||^4.0",
        "pestphp/pest-plugin-laravel": "^2.0||^3.0||^4.0"
    },
    "autoload": {
        "psr-4": {
            "MrJin\\FilamentMediaBrowser\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MrJin\\FilamentMediaBrowser\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MrJin\\FilamentMediaBrowser\\FilamentMediaBrowserServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
